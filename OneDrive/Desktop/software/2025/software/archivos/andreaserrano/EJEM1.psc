Algoritmo ejercicionuevo
	Definir edad Como Entero
	Definir nombre, apellido Como Caracter
	escribir "Ingrese la edad; ";
	leer edad;
	Si edad >18 Entonces
		escribir "Ingresa tu nombre";
		leer nombre;
		escribir  "Ingresa tu apellido";
		leer apellido;
		imprimir "holas" nombre, apellido;
	SiNo
		imprimir "estas chikito";
	Fin Si
FinAlgoritmo
